# StudyPilot Local V2
# 默认使用真实 LM Studio API。
# 如果没有启动 LM Studio，可将 STUDYPILOT_USE_MOCK_LLM 改成 true。

STUDYPILOT_ENV=local
STUDYPILOT_DATA_DIR=data

# LM Studio OpenAI-compatible API
STUDYPILOT_LM_STUDIO_BASE_URL=http://localhost:1234/v1
STUDYPILOT_MODEL_NAME=gemma-4-26b-a4b-instruct
STUDYPILOT_LLM_TEMPERATURE=0.2
STUDYPILOT_LLM_MAX_TOKENS=1800
STUDYPILOT_LLM_TIMEOUT_SECONDS=90

# Mock / fallback
STUDYPILOT_USE_MOCK_LLM=false
STUDYPILOT_LLM_FALLBACK_TO_MOCK=false

# App ports
STUDYPILOT_STREAMLIT_PORT=8501
STUDYPILOT_API_PORT=8000

# Rule engine defaults
STUDYPILOT_NORMAL_MAX_MINUTES=60
STUDYPILOT_TIRED_MAX_MINUTES=40
STUDYPILOT_EXHAUSTED_MAX_MINUTES=25
STUDYPILOT_MAX_CORE_TASKS_WEEKDAY=3
STUDYPILOT_NO_HIGH_INTENSITY_AFTER=21:30

# Product behavior
STUDYPILOT_PARENT_CONFIRM_REQUIRED=true
STUDYPILOT_LOG_LEVEL=INFO
