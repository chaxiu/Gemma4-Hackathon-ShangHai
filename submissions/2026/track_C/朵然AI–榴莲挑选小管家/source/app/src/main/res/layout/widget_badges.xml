<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_badges_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍈"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/widgets_badges_title"
            android:textStyle="bold"
            android:textSize="14sp" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/widget_badge_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:columnCount="3"
        android:rowCount="2"
        android:alignmentMode="alignMargins">

        <ImageView
            android:id="@+id/badge_1"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/meiriyijian" />

        <ImageView
            android:id="@+id/badge_2"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/paileixianfeng" />

        <ImageView
            android:id="@+id/badge_3"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/pinzhibushou" />

        <ImageView
            android:id="@+id/badge_4"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:layout_row="1"
            android:layout_column="0"
            android:scaleType="fitCenter"
            android:src="@drawable/tujiandaren" />

        <ImageView
            android:id="@+id/badge_5"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:layout_row="1"
            android:layout_column="1"
            android:scaleType="fitCenter"
            android:src="@drawable/kuangreguofen" />
    </GridLayout>
</LinearLayout>
